# PostgreSQL connection string (required)
# Local: postgresql://user:password@localhost:5432/bimmerhub
# Vercel Postgres: automatically set when you connect a database
DATABASE_URL="postgresql://user:password@localhost:5432/bimmerhub"

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-string"

# Trust proxy headers (required for Vercel)
AUTH_TRUST_HOST=true

# Public URL of the app (used for SEO, sitemap, canonical URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google Analytics measurement ID (optional)
NEXT_PUBLIC_GA_ID="G-W75TCTL3QS"
